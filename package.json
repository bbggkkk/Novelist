{
  "name": "novelist-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server Boilerplate — Model Context Protocol",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --clean",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect": "HOST=0.0.0.0 npx @modelcontextprotocol/inspector -- tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "server"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": "^20.0.0"
  }
}